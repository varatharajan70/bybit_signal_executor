# Copy to .env (gitignored) and fill in real values. Never commit .env.
#
# Demo credentials (env-only, no hardcoded fallback in config/settings.py).
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=

# Live credentials: no fallback exists in code. Leave blank until you are actually
# ready to go live - see the two-key gate below.
BYBIT_LIVE_API_KEY=
BYBIT_LIVE_API_SECRET=

# TRADING_ENV selects demo (default) or live. Going live ALSO requires
# LIVE_TRADING_CONFIRM to exactly match the phrase below - both must be set, or the
# app forces itself back to demo. This is deliberate: one flag alone is not enough.
TRADING_ENV=demo
LIVE_TRADING_CONFIRM=

# Risk plan: "A" ($2.5 risk, 2-stage SL trail) or "B" ($4 risk, 3-stage SL trail).
# See config/settings.py RISK_PLANS for the exact trail shape of each.
RISK_PLAN=A

# Telegram user-account client credentials (for telegram_bot/listener.py)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHANNEL=

# Telegram BOT for outgoing notifications (signal received, order placed/failed,
# position closed, daily summary). Separate from the listener account above -
# create via @BotFather, message the bot once, then fetch your chat ID.
BOT_TOKEN=
CHAT_ID=
